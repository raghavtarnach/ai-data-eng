# ─── AI Data Engineering System ─────────────────────────────────────────
# Copy this file to .env and fill in your values.

# ─── LLM Provider (Anthropic Claude) ───────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key-here
LLM_MODEL=claude-sonnet-4-20250514
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096

# ─── PostgreSQL ────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_data_eng
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# ─── Sandbox ───────────────────────────────────────────────────────────
SANDBOX_IMAGE=ai-data-eng-sandbox:latest
SANDBOX_CPU_LIMIT=2.0
SANDBOX_MEMORY_LIMIT=4g
SANDBOX_PYTHON_TIMEOUT=300
SANDBOX_SQL_TIMEOUT=60
SANDBOX_OUTPUT_CAP_MB=500

# ─── Storage ───────────────────────────────────────────────────────────
STORAGE_ROOT=./artifacts

# ─── Observability ─────────────────────────────────────────────────────
LOG_LEVEL=INFO
# OTEL_EXPORTER_OTLP_ENDPOINT=  # Set for production (e.g., Azure Monitor)

# ─── Orchestrator ─────────────────────────────────────────────────────
MAX_RETRIES=3
MAX_FIX_CYCLES=3
